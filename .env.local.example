# ============================================
# AGUA VIFLOMAX — Variables de Entorno
# ============================================
# Copiar este archivo a .env.local y completar con los valores reales
# NUNCA commitear .env.local al repositorio

# ============================================
# SUPABASE
# ============================================
# URL del proyecto Supabase (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key pública (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key PRIVADA — solo para operaciones server-side
# NUNCA exponer en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ============================================
# WHATSAPP
# ============================================
# Número de WhatsApp de la empresa (formato: 56XXXXXXXXX, sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=56912345678

# ============================================
# GOOGLE MAPS (opcional)
# ============================================
# API Key de Google Maps (para mapa de cobertura)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ============================================
# NOTIFICACIONES (opcional)
# ============================================
# Resend API Key para emails de notificación de pedidos
RESEND_API_KEY=re_...

# Email del administrador para recibir notificaciones
NOTIFICATION_EMAIL=admin@viflomax.cl
