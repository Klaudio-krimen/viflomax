# ============================================
# AGUA VIFLOMAX — Variables de Entorno
# ============================================
# Copiar este archivo a .env.local y completar con los valores reales
# NUNCA commitear .env.local al repositorio

# ============================================
# DATABASE (Railway PostgreSQL)
# ============================================
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@railway.host:5432/railway

# ============================================
# NEXTAUTH
# ============================================
# URL base del sitio (cambiar en producción a la URL de Vercel)
NEXTAUTH_URL=http://localhost:3000

# Secret aleatorio para firmar tokens JWT
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=tu_secret_aleatorio_aqui

# ============================================
# CLOUDINARY (fotos de entregas)
# ============================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
# Upload preset público (para subir desde el cliente)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=viflomax_entregas

# ============================================
# WHATSAPP
# ============================================
# Número de WhatsApp de la empresa (formato: 56XXXXXXXXX, sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=56912345678

# ============================================
# GOOGLE MAPS (opcional)
# ============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ============================================
# NOTIFICACIONES (opcional)
# ============================================
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=admin@viflomax.cl
